# ── Database ────────────────────────────────────────────────────────────────────
POSTGRES_USER=streetfeed
POSTGRES_PASSWORD=changeme_strong_password

# Only read directly by root docker-compose.yml (local dev base config) if you
# ever run it without the docker-compose.dev.yml override, which normally
# supplies its own DATABASE_URL instead. docker-compose.nas.yml (production)
# builds its own connection string from POSTGRES_USER/POSTGRES_PASSWORD above
# and does not need this var.
DATABASE_URL=postgresql://streetfeed:changeme_strong_password@db:5432/streetfeed

# ── App URL ──────────────────────────────────────────────────────────────────────
APP_URL=https://streetfeed.nl

# ── Email (choose Resend OR SMTP) ────────────────────────────────────────────────
# Option A: Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option B: SMTP (Nodemailer fallback)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password

EMAIL_FROM=Streetfeed <noreply@streetfeed.nl>

# ── Push Notifications (VAPID) ───────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@streetfeed.nl

# ── Photo storage ────────────────────────────────────────────────────────────────
# Local disk, mounted as a Docker volume in production (see docker-compose.nas.yml).
# Defaults to /data/photos if unset.
# UPLOAD_DIR=/data/photos

# ── Cloudflare Tunnel (production only) ─────────────────────────────────────────
# Required by the cloudflared service in docker-compose.nas.yml — terminates
# TLS for streetfeed.nl. Get this from the Cloudflare Zero Trust dashboard:
# Networks → Tunnels → (your tunnel) → Configure → Install and run a connector.
# Without this set, cloudflared silently runs with an empty token and the
# tunnel won't connect.
CLOUDFLARE_TUNNEL_TOKEN=
